# Copy this to .env and fill in at least one LLM key.

# ── LLM Provider (pick one) ──────────────────────────────────────────────────
# Option A: Groq — FREE tier, Llama 3.3 70B, 14,400 req/day
# Sign up at https://console.groq.com → API Keys
GROQ_API_KEY=

# Option B: Anthropic — Paid, Claude Haiku (~$0.25/1M tokens)
# Sign up at https://console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=

# ── Embeddings ───────────────────────────────────────────────────────────────
# Runs locally — no API key needed
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Storage ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma

# ── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=5
